<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connectivity Monitor"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wi-Fi · Bluetooth · GNSS"
            android:textSize="13sp"
            android:textColor="#6C757D"
            android:layout_marginBottom="20dp" />

        <!-- Cartão de Status -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Wi-Fi -->
                <TextView
                    android:id="@+id/tvWifiStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ Wi-Fi: verificando…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/tvWifiSsid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SSID: -"
                    android:textSize="13sp"
                    android:textColor="#6C757D"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E9ECEF"
                    android:layout_marginBottom="12dp" />

                <!-- Bluetooth -->
                <TextView
                    android:id="@+id/tvBtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ Bluetooth: verificando…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E9ECEF"
                    android:layout_marginBottom="12dp" />

                <!-- GNSS -->
                <TextView
                    android:id="@+id/tvGnssStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ GNSS: aguardando…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/tvGnssInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satélites: -"
                    android:textSize="13sp"
                    android:textColor="#6C757D"
                    android:layout_marginStart="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Log de eventos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOG DE EVENTOS"
            android:textSize="11sp"
            android:textColor="#6C757D"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEvents"
            android:layout_width="match_parent"
            android:layout_height="400dp" />

    </LinearLayout>
</ScrollView>